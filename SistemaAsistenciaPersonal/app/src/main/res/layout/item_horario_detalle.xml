<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#F8FAFC"
    app:strokeColor="#E3EDF7"
    app:strokeWidth="1dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_blob_blue">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_book"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMateria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HISTORIA"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#163B73" />

            <TextView
                android:id="@+id/tvDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2°B · Lunes"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvHorario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:11:00 – 10:00:00"
                android:textSize="12sp"
                android:textColor="#006847"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEliminar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            android:scaleType="centerInside"
            android:contentDescription="Eliminar"
            app:tint="#D32F2F" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
