<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#E8EEF5"
    app:strokeWidth="1dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNombreMaestro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Maestro"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#163B73" />

        <TextView
            android:id="@+id/tvContrato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiempo Completo"
            android:textSize="11sp"
            android:textColor="#64748B"
            android:layout_marginTop="4dp" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:background="#F8FAFC"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Retardos" android:textSize="10sp" android:textColor="#94A3B8" android:textAllCaps="true" />
                <TextView android:id="@+id/tvRetardos" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="#D32F2F" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Minutos" android:textSize="10sp" android:textColor="#94A3B8" android:textAllCaps="true" />
                <TextView android:id="@+id/tvMinutos" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="#E65100" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ausencias" android:textSize="10sp" android:textColor="#94A3B8" android:textAllCaps="true" />
                <TextView android:id="@+id/tvAusencias" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="#163B73" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>