<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#E8EEF5"
    app:strokeWidth="1dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Imagen de huella o placeholder -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#F0F4F8">

            <ImageView
                android:id="@+id/ivHuella"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_lock"
                android:padding="14dp"
                app:tint="#94A3B8"
                android:contentDescription="Huella dactilar" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Info del maestro -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreMaestro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del Maestro"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#163B73" />

            <TextView
                android:id="@+id/tvContrato"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiempo Completo"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvFechaHuella"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrada: 2026-04-18"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Badge de estado -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Registrada"
            android:textSize="11sp"
            android:textColor="#006847"
            android:textStyle="bold"
            android:background="#E8F5E9"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
